# FeedForward Frontend Environment Variables
# Copy this to .env and fill in your values

# API URL (your backend server)
VITE_API_URL=http://localhost:5000/api

# Optional: Google Maps API key (for geocoding)
# VITE_GOOGLE_MAPS_KEY=your_google_maps_api_key

# Optional: Web Push (VAPID) — generate keys with: npx web-push generate-vapid-keys
# Add public key here; add private key to backend/.env as VAPID_PRIVATE_KEY
# VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here
